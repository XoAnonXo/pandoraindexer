{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "noEmit": true
  },
  "include": ["ponder-env.d.ts", "src/**/*.ts", "ponder.config.ts", "ponder.schema.ts", "abis/**/*.ts"],
  "exclude": ["node_modules", ".ponder"]
}

